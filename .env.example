# Copy this file to .env at the repo root (gitignored) and fill in real values.
# NEVER commit .env. NEVER paste a real token into chat, issues, or commits.
# The app loads the repo-root .env (then backend/.env if present) automatically
# — see config/settings/base.py: load_dotenv.
#
# TELEGRAM_BOT_TOKEN must be EXACTLY the @BotFather token: <digits>:<~35 chars>,
# one colon, nothing else on the line (no label, no quotes, no extra paste).

# --- Telegram bot (Phase 4.5 phone dispatch) -------------------------------
# Token from @BotFather (/newbot). Keep it secret; rotate via /revoke if exposed.
TELEGRAM_BOT_TOKEN=000000000:replace-with-your-botfather-token

# Comma-separated Telegram chat IDs allowed to use the bot. EMPTY = nobody.
# Find yours by messaging @userinfobot on Telegram.
TELEGRAM_ALLOWED_CHAT_IDS=123456789

# Ollama model used for Telegram-created threads (routes via local Ollama).
TELEGRAM_DEFAULT_MODEL=kimi-k2.6:cloud

# --- Optional: override the dev defaults if needed -------------------------
# SECRET_KEY=change-me-in-production
# ALLOWED_HOSTS=localhost,127.0.0.1
# POSTGRES_DB=agent_command_center
# POSTGRES_USER=acc_user
# POSTGRES_PASSWORD=acc_password
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# REDIS_URL=redis://localhost:6379/0
