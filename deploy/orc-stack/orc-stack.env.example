# orc-stack shared config — copy this to orc-stack.env and fill in your paths.
# orc-stack.env is gitignored (contains local machine paths).
# Single source of truth for the supervised stack (daphne + bot + host daemon).
# After editing: launchctl kickstart -k gui/$(id -u)/com.openremote.<svc>

# Repo + tool locations (adjust to your machine)
ORC_REPO="/path/to/OpenRemote-Control"
ORC_PATH_EXTRA="/usr/local/bin:/opt/homebrew/bin"

# Django settings for the local single-host deploy
export DJANGO_SETTINGS_MODULE="config.settings.local"

# Driving engine for headless sessions:
#   sdk  → Claude Agent SDK with per-tool Allow/Deny chat approval
#   (unset / empty) → claude -p --permission-mode bypassPermissions (no gate)
# Rollback switch: set to "" to fall back to the legacy claude -p path.
export ORC_HEADLESS_ENGINE="sdk"

# Telegram reply delivery: "all" posts each turn as a fresh full message
# (turn-by-turn driving); "progress" collapses into one edited digest.
export OBSERVE_DELIVERY_MODE="all"

# Runtimes the host daemon observes (read-only mirrors). Empty = inject/headless
# only (no mirror topics). Set e.g. "claude_code,codex,opencode" to mirror those.
export OBSERVE_RUNTIMES=""
