# Copy to deploy/.env (gitignored) — quickstart.sh does this for you. Never commit the filled-in file.

# --- Django (auto-generated by quickstart.sh) ---
SECRET_KEY=CHANGEME-generated-by-quickstart
ALLOWED_HOSTS=localhost,127.0.0.1,web
ORC_PUBLIC_BASE_URL=http://localhost:8000

# --- Postgres (auto-generated by quickstart.sh; POSTGRES_HOST=postgres is the compose service name) ---
POSTGRES_DB=openremote_control
POSTGRES_USER=orc
POSTGRES_PASSWORD=CHANGEME-generated-by-quickstart
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Valkey / Redis (auto-generated by quickstart.sh) ---
REDIS_URL=redis://valkey:6379/0

# --- Host enrollment + connector/gateway tokens (auto-generated by quickstart.sh) ---
ORC_ENROLL_SECRET=CHANGEME-generated-by-quickstart
ORC_CONNECTOR_TOKEN=CHANGEME-generated-by-quickstart
MESSAGING_GATEWAY_TOKEN=CHANGEME-generated-by-quickstart

# --- Telegram (bot token user-supplied; chat ids auto-discovered by quickstart.sh) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_FORUM_CHAT_ID=
