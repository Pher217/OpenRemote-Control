# deploy/.env.example
# Copy to deploy/.env and fill in every value before starting any stack.
# Generate SECRET_KEY with: python -c "import secrets; print(secrets.token_urlsafe(50))"
# This file is committed; deploy/.env is gitignored.

# ---------------------------------------------------------------------------
# Domains  (set DNS A records pointing both to your server IP)
# ---------------------------------------------------------------------------
APP_DOMAIN=app.example.com
HS_DOMAIN=headscale.example.com

# ---------------------------------------------------------------------------
# Django — core
# ---------------------------------------------------------------------------
# Generate: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=change-me-generate-a-real-key

DEBUG=False

# Comma-separated. Include the app domain + internal hostnames so healthchecks work.
ALLOWED_HOSTS=app.example.com,web,localhost,127.0.0.1

# Comma-separated origins allowed in CSRF checks (must include https:// scheme).
CSRF_TRUSTED_ORIGINS=https://app.example.com

# Tells Django it's behind a TLS-terminating proxy (Caddy sets X-Forwarded-Proto).
# Format: header_name,expected_value
SECURE_PROXY_SSL_HEADER=HTTP_X_FORWARDED_PROTO,https

# ---------------------------------------------------------------------------
# Database — app postgres
# ---------------------------------------------------------------------------
POSTGRES_DB=openremote_control
POSTGRES_USER=orc_user
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ---------------------------------------------------------------------------
# Redis / Valkey (used for cache, Channels, and Celery broker)
# ---------------------------------------------------------------------------
REDIS_URL=redis://valkey:6379/0

# ---------------------------------------------------------------------------
# ORC application tokens
# ---------------------------------------------------------------------------
# Token that host-agents and MCP connectors use to authenticate to the backend.
ORC_CONNECTOR_TOKEN=change-me-generate-a-random-token

# Secret used by host-agents during enrollment (orc-host enroll --secret).
ORC_ENROLL_SECRET=change-me-generate-a-random-secret

# ---------------------------------------------------------------------------
# Telegram adapter  (Telegram bot runs inside the app stack)
# ---------------------------------------------------------------------------
# BotFather token for your Telegram bot.
TELEGRAM_BOT_TOKEN=1234567890:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# Comma-separated chat IDs that are allowed to interact with the bot.
# Get your chat ID: message @userinfobot in Telegram.
TELEGRAM_ALLOWED_CHAT_IDS=123456789

# For forum-mode groups: the supergroup chat ID (usually negative).
TELEGRAM_FORUM_CHAT_ID=

# Chat / topic ID where the Telegram bot posts approval prompts.
ORC_PROMPT_CHAT_ID=123456789

# ---------------------------------------------------------------------------
# Messaging — single app of choice
# ---------------------------------------------------------------------------
# ORC delivers every session/prompt to exactly ONE messaging app.
# Set this to the platform you want to use:
#   telegram | whatsapp | slack | signal | imessage | discord
#
# Then configure ONLY that platform's recipient variable:
#   telegram  → ORC_PROMPT_CHAT_ID      (Telegram chat ID)
#   whatsapp  → ORC_PROMPT_WHATSAPP     (international phone number)
#   slack     → ORC_PROMPT_SLACK        (channel ID or user ID)
#   signal    → ORC_PROMPT_SIGNAL       (international phone number)
#   imessage  → ORC_PROMPT_IMESSAGE     (Apple ID email or phone number)
#   discord   → ORC_PROMPT_DISCORD      (channel ID)
#
# This is NOT a broadcast / multi-app fan-out — one app gets everything.
# For gateway platforms (all except telegram) also set ENABLED_PLATFORMS below.
ORC_MESSAGING_PLATFORM=telegram

# ---------------------------------------------------------------------------
# Messaging gateway — backend ↔ gateway auth
# ---------------------------------------------------------------------------
# Shared bearer token.  The backend uses this to authenticate gateway calls;
# the gateway includes it in every request to /api/gateway/*.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
MESSAGING_GATEWAY_TOKEN=change-me-generate-a-random-token

# ---------------------------------------------------------------------------
# Messaging gateway — per-platform prompt recipients
# These are the platform-specific addresses where ORC posts approval prompts.
# Format depends on the platform (phone number, channel ID, user ID, etc.).
# ---------------------------------------------------------------------------

# WhatsApp: phone number in international format, e.g. +41791234567
ORC_PROMPT_WHATSAPP=

# Slack: channel ID (e.g. C01234ABCDE) or user ID (e.g. U01234ABCDE)
ORC_PROMPT_SLACK=

# Discord: channel ID (copy from Discord — enable Developer Mode in settings)
ORC_PROMPT_DISCORD=

# Signal: phone number in international format, e.g. +41791234567
ORC_PROMPT_SIGNAL=

# iMessage: Apple ID email or phone number, e.g. +41791234567
ORC_PROMPT_IMESSAGE=

# ---------------------------------------------------------------------------
# Messaging gateway — service configuration
# ---------------------------------------------------------------------------
# URL of the backend as seen from within the Docker network.
BACKEND_URL=http://web:8000

# Comma-separated list of platforms to enable.
# Available: whatsapp, slack, discord, signal, imessage
# Only configure tokens for platforms you list here.
ENABLED_PLATFORMS=whatsapp,slack,signal

# How often (ms) the gateway polls /api/gateway/outbox for pending messages.
POLL_INTERVAL_MS=5000

# ---------------------------------------------------------------------------
# Messaging gateway — Slack
# Requires a Slack app with Socket Mode enabled.
# Scopes: chat:write, im:history, im:read, im:write, channels:history (bot token)
# ---------------------------------------------------------------------------
SLACK_BOT_TOKEN=xoxb-change-me
SLACK_APP_TOKEN=xapp-1-change-me

# ---------------------------------------------------------------------------
# Messaging gateway — Discord
# Requires a bot token with Message Content Intent enabled.
# ---------------------------------------------------------------------------
DISCORD_TOKEN=change-me-discord-bot-token

# ---------------------------------------------------------------------------
# Messaging gateway — Signal (via signal-cli-rest-api)
# Docs: https://github.com/bbernhard/signal-cli-rest-api
# The signal-cli-rest-api container runs in the app stack.
# ---------------------------------------------------------------------------
# Internal URL of the signal-cli-rest-api container (not exposed publicly).
SIGNAL_API_URL=http://signal-cli-rest-api:8080

# Phone number registered/linked in signal-cli-rest-api (international format).
SIGNAL_NUMBER=+41791234567

# ---------------------------------------------------------------------------
# Messaging gateway — iMessage (via BlueBubbles on a Mac)
# BlueBubbles is NOT a container; it must run on a Mac with iMessage.
# Docs: https://bluebubbles.app/install/
# The Mac connects to this server via the Headscale mesh (or direct LAN).
# BlueBubbles POSTs inbound messages to the gateway's webhook port below;
# the gateway calls BlueBubbles to send outbound iMessages.
# ---------------------------------------------------------------------------
# Base URL of your BlueBubbles server (running on the Mac), reachable from
# the gateway container via the Headscale mesh or local network.
BLUEBUBBLES_URL=http://192.168.1.x:1234

# BlueBubbles server password (set during BlueBubbles setup).
BLUEBUBBLES_PASSWORD=change-me-bluebubbles-password

# Port the gateway listens on for inbound webhooks from BlueBubbles.
# Bind this to the Tailscale/mesh interface on the server — do NOT expose
# it via Caddy (the Mac reaches it over the Headscale mesh, not the internet).
IMESSAGE_WEBHOOK_PORT=3001

# ---------------------------------------------------------------------------
# Session observer
# ---------------------------------------------------------------------------
# Comma-separated runtime identifiers to observe.
# Example: claude_code,codex
OBSERVE_RUNTIMES=claude_code,codex
